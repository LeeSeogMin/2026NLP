flowchart TB
    subgraph docs["클러스터별 문서"]
        direction LR
        C0["클러스터 0\n(경제 관련)"]
        C1["클러스터 1\n(스포츠 관련)"]
        C2["클러스터 2\n(기술 관련)"]
    end

    subgraph merge["문서 결합"]
        direction LR
        M0["슈퍼 문서 0"]
        M1["슈퍼 문서 1"]
        M2["슈퍼 문서 2"]
    end

    C0 --> M0
    C1 --> M1
    C2 --> M2

    subgraph tf["TF 계산 (Term Frequency)"]
        direction TB
        TF_FORMULA["TF(t, c) = 클래스 c 내 단어 t 빈도 / 클래스 c 총 단어 수"]
    end

    subgraph idf["IDF 계산 (Inverse Document Frequency)"]
        direction TB
        IDF_FORMULA["IDF(t) = log(1 + A / f(t))\nA: 전체 문서 수\nf(t): 단어 t 등장 문서 수"]
    end

    subgraph ctfidf["c-TF-IDF 계산"]
        FORMULA["c-TF-IDF(t, c) = TF(t, c) × IDF(t)"]
    end

    M0 --> tf
    M1 --> tf
    M2 --> tf

    tf --> ctfidf
    idf --> ctfidf

    subgraph result["결과: 토픽별 키워드"]
        direction LR
        R0["토픽 0: 반도체, 금리, 환율..."]
        R1["토픽 1: 축구, 야구, 골프..."]
        R2["토픽 2: AI, 챗봇, 클라우드..."]
    end

    ctfidf --> R0
    ctfidf --> R1
    ctfidf --> R2

    style C0 fill:#ffcdd2
    style C1 fill:#c8e6c9
    style C2 fill:#bbdefb
    style FORMULA fill:#fff9c4
    style R0 fill:#ffcdd2
    style R1 fill:#c8e6c9
    style R2 fill:#bbdefb
