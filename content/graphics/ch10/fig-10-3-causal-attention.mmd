%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#34a853'}}}%%
flowchart TB
    subgraph causal["Causal (Masked) Self-Attention"]
        direction TB

        subgraph tokens["입력 토큰"]
            t1["The"]
            t2["cat"]
            t3["sat"]
            t4["on"]
        end

        subgraph mask["어텐션 마스크 (하삼각 행렬)"]
            direction LR
            matrix["
            ┌─────────────────────┐
            │  The  cat  sat  on  │
            ├─────────────────────┤
            │   1    0    0   0   │ The
            │   1    1    0   0   │ cat
            │   1    1    1   0   │ sat
            │   1    1    1   1   │ on
            └─────────────────────┘
            1 = 참조 가능
            0 = 마스킹 (참조 불가)
            "]
        end

        subgraph effect["효과"]
            e1["The → The만 참조"]
            e2["cat → The, cat 참조"]
            e3["sat → The, cat, sat 참조"]
            e4["on → 모든 이전 토큰 참조"]
        end
    end

    subgraph why["왜 필요한가?"]
        reason1["1. 미래 정보 유출 방지"]
        reason2["2. 실제 생성 시와 동일한 조건"]
        reason3["3. 자기회귀 특성 유지"]
    end

    tokens --> mask
    mask --> effect
    effect --> why

    style causal fill:#e8f5e9,stroke:#388e3c
    style mask fill:#fff9c4,stroke:#f9a825
    style why fill:#fce4ec,stroke:#c2185b
