%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#4285f4'}}}%%
flowchart TB
    subgraph ar["자기회귀 언어 모델 (GPT)"]
        direction TB
        ar_input["입력: The cat sat on the"]
        ar_model["GPT<br/>(Decoder-only)"]
        ar_output["예측: mat"]

        ar_direction["단방향 문맥<br/>← 왼쪽만 참조"]

        ar_input --> ar_model
        ar_model --> ar_output
        ar_direction -.-> ar_model
    end

    subgraph mlm["마스크 언어 모델 (BERT)"]
        direction TB
        mlm_input["입력: The cat [MASK] on the mat"]
        mlm_model["BERT<br/>(Encoder-only)"]
        mlm_output["예측: sat"]

        mlm_direction["양방향 문맥<br/>← 왼쪽 + 오른쪽 →"]

        mlm_input --> mlm_model
        mlm_model --> mlm_output
        mlm_direction -.-> mlm_model
    end

    subgraph compare["비교"]
        direction LR
        gpt_use["GPT 용도:<br/>텍스트 생성"]
        bert_use["BERT 용도:<br/>텍스트 이해"]
    end

    ar --> compare
    mlm --> compare

    style ar fill:#e8f5e9,stroke:#388e3c
    style mlm fill:#e3f2fd,stroke:#1976d2
    style ar_model fill:#34a853,stroke:#1e7e34,color:#fff
    style mlm_model fill:#4285f4,stroke:#1565c0,color:#fff
    style compare fill:#fff3e0,stroke:#f57c00
