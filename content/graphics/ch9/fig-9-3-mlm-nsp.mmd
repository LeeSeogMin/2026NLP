flowchart TB
    subgraph mlm["Masked Language Model (MLM)"]
        direction TB
        input1["입력: The cat [MASK] on the mat"]
        bert1["BERT Encoder"]
        output1["예측: sat"]

        mask_strategy["마스킹 전략 (15% 토큰)<br/>80%: [MASK]로 대체<br/>10%: 랜덤 토큰<br/>10%: 원본 유지"]

        input1 --> bert1
        bert1 --> output1
        mask_strategy -.-> input1
    end

    subgraph nsp["Next Sentence Prediction (NSP)"]
        direction TB
        sent_a["문장 A: BERT is powerful"]
        sent_b["문장 B: It understands context"]

        input2["[CLS] 문장A [SEP] 문장B [SEP]"]
        bert2["BERT Encoder"]
        cls_token["[CLS] 토큰 출력"]
        classifier["이진 분류"]
        result["IsNext / NotNext"]

        sent_a --> input2
        sent_b --> input2
        input2 --> bert2
        bert2 --> cls_token
        cls_token --> classifier
        classifier --> result
    end

    style mlm fill:#e3f2fd,stroke:#1976d2
    style nsp fill:#fce4ec,stroke:#c2185b
    style bert1 fill:#4285f4,stroke:#1565c0,color:#fff
