flowchart TD
    subgraph epoch["에폭 (Epoch)"]
        direction TB
        A[데이터 로드] --> B[배치 순회]

        subgraph training["Training Loop"]
            B --> C[model.train]
            C --> D[순전파<br/>outputs = model - x]
            D --> E[손실 계산<br/>loss = criterion - outputs, y]
            E --> F[역전파<br/>loss.backward]
            F --> G[파라미터 업데이트<br/>optimizer.step]
            G --> H{더 많은<br/>배치?}
            H -->|예| C
        end

        subgraph validation["Validation Loop"]
            H -->|아니오| I[model.eval]
            I --> J["torch.no_grad()"]
            J --> K[순전파]
            K --> L[손실/정확도 계산]
        end

        L --> M{더 많은<br/>에폭?}
        M -->|예| A
        M -->|아니오| N[학습 완료]
    end

    style training fill:#e1f5fe
    style validation fill:#fff3e0
    style C fill:#bbdefb
    style I fill:#ffcc80
