flowchart LR
    subgraph forward["순전파 (Forward Pass)"]
        direction LR
        A["입력 x"] -->|"w × x + b"| B["은닉층"]
        B -->|"ReLU"| C["활성화"]
        C -->|"w × h + b"| D["출력 ŷ"]
    end

    D -->|"ŷ vs y"| E["손실 L"]

    subgraph backward["역전파 (Backward Pass)"]
        direction RL
        E -->|"∂L/∂ŷ"| F["출력 그래디언트"]
        F -->|"∂L/∂w₂"| G["은닉층 그래디언트"]
        G -->|"∂L/∂w₁"| H["입력 그래디언트"]
    end

    H -->|"w = w - lr × ∂L/∂w"| I["파라미터 업데이트"]

    style forward fill:#e3f2fd
    style backward fill:#fce4ec
    style E fill:#fff9c4
    style I fill:#e8f5e9
