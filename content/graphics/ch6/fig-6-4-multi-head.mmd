flowchart TB
    subgraph inputs["입력"]
        Q["Q"]
        K["K"]
        V["V"]
    end

    subgraph heads["Multi-Head Attention"]
        direction TB

        subgraph head1["Head 1"]
            H1["Attention"]
        end

        subgraph head2["Head 2"]
            H2["Attention"]
        end

        subgraph head3["Head 3"]
            H3["Attention"]
        end

        subgraph headn["Head h"]
            Hn["Attention"]
        end
    end

    concat["Concat"]
    linear["Linear (W^O)"]
    output["Output"]

    Q --> head1 & head2 & head3 & headn
    K --> head1 & head2 & head3 & headn
    V --> head1 & head2 & head3 & headn

    H1 --> concat
    H2 --> concat
    H3 --> concat
    Hn --> concat
    concat --> linear
    linear --> output

    style H1 fill:#ffcdd2
    style H2 fill:#c8e6c9
    style H3 fill:#bbdefb
    style Hn fill:#fff9c4
    style output fill:#e1bee7
