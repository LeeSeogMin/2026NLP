flowchart TB
    subgraph encoder["Encoder (×N)"]
        direction TB

        IE["Input Embedding"]
        PE1["+ Positional Encoding"]

        subgraph enc_block["Encoder Block"]
            MHA1["Multi-Head<br/>Self-Attention"]
            AN1["Add & Norm"]
            FFN1["Feed Forward"]
            AN2["Add & Norm"]
        end

        IE --> PE1
        PE1 --> MHA1
        MHA1 --> AN1
        PE1 -.-> AN1
        AN1 --> FFN1
        FFN1 --> AN2
        AN1 -.-> AN2
    end

    subgraph decoder["Decoder (×N)"]
        direction TB

        OE["Output Embedding"]
        PE2["+ Positional Encoding"]

        subgraph dec_block["Decoder Block"]
            MMHA["Masked Multi-Head<br/>Self-Attention"]
            AN3["Add & Norm"]
            CA["Cross-Attention<br/>(Encoder-Decoder)"]
            AN4["Add & Norm"]
            FFN2["Feed Forward"]
            AN5["Add & Norm"]
        end

        OE --> PE2
        PE2 --> MMHA
        MMHA --> AN3
        PE2 -.-> AN3
        AN3 --> CA
        CA --> AN4
        AN3 -.-> AN4
        AN4 --> FFN2
        FFN2 --> AN5
        AN4 -.-> AN5
    end

    AN2 --> CA

    Linear["Linear"]
    Softmax["Softmax"]
    Output["Output<br/>Probabilities"]

    AN5 --> Linear
    Linear --> Softmax
    Softmax --> Output

    style MHA1 fill:#bbdefb
    style MMHA fill:#ffcdd2
    style CA fill:#c8e6c9
    style FFN1 fill:#fff9c4
    style FFN2 fill:#fff9c4
