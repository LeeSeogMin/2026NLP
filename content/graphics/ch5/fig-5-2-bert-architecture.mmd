flowchart TB
    subgraph input["입력 처리"]
        direction LR
        tokens["[CLS] 토큰₁ 토큰₂ ... [SEP] 토큰₃ ... [SEP]"]

        subgraph embed["세 가지 임베딩의 합"]
            direction TB
            te["Token Embedding<br/>(WordPiece 토큰 → 768차원)"]
            se["Segment Embedding<br/>(문장 A=0, 문장 B=1)"]
            pe["Position Embedding<br/>(위치 0, 1, 2, ...)"]
        end

        tokens --> embed
    end

    subgraph encoder["Transformer Encoder (12 layers)"]
        direction TB
        layer1["Layer 1: Multi-Head Self-Attention + FFN"]
        layer2["Layer 2: Multi-Head Self-Attention + FFN"]
        dots["... (양방향: 모든 토큰이 서로 참조)"]
        layer12["Layer 12: Multi-Head Self-Attention + FFN"]

        layer1 --> layer2 --> dots --> layer12
    end

    subgraph pretask["사전학습 태스크"]
        direction LR
        mlm["MLM<br/>마스크 토큰 예측<br/>(15% 마스킹)"]
        nsp["NSP<br/>다음 문장 예측<br/>(IsNext / NotNext)"]
    end

    subgraph output["출력"]
        direction LR
        cls["[CLS] 출력<br/>→ 문장 표현<br/>(분류 태스크)"]
        tok["토큰별 출력<br/>→ 각 768차원<br/>(NER, MLM)"]
    end

    embed --> encoder
    encoder --> pretask
    encoder --> output
