flowchart TB
    subgraph inputs["입력"]
        Ct1["C_{t-1}<br/>이전 Cell State"]
        ht1["h_{t-1}<br/>이전 Hidden State"]
        xt["x_t<br/>현재 입력"]
    end

    subgraph gates["게이트"]
        direction LR
        fg["Forget Gate<br/>f_t = σ(...)"]
        ig["Input Gate<br/>i_t = σ(...)"]
        cg["Cell Gate<br/>g_t = tanh(...)"]
        og["Output Gate<br/>o_t = σ(...)"]
    end

    subgraph update["Cell State 업데이트"]
        mul1["⊙"]
        mul2["⊙"]
        add["+"]
        Ct["C_t<br/>새 Cell State"]
    end

    subgraph output["출력"]
        tanh1["tanh"]
        mul3["⊙"]
        ht["h_t<br/>새 Hidden State"]
    end

    Ct1 --> mul1
    fg --> mul1
    mul1 --> add

    ig --> mul2
    cg --> mul2
    mul2 --> add

    add --> Ct
    Ct --> tanh1
    tanh1 --> mul3
    og --> mul3
    mul3 --> ht

    ht1 --> fg
    ht1 --> ig
    ht1 --> cg
    ht1 --> og

    xt --> fg
    xt --> ig
    xt --> cg
    xt --> og

    style fg fill:#ffcdd2
    style ig fill:#c8e6c9
    style cg fill:#fff9c4
    style og fill:#bbdefb
    style Ct fill:#e1bee7
    style ht fill:#b2dfdb
